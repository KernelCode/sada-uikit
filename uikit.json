{
  "$schema": "https://uikit.dev/schema/v1.json",
  "manifestVersion": 1,
  "id": "sada",
  "name": "Sada",
  "version": "1.0.0",
  "description": "An editorial audio & video media-platform kit — cream paper, ink black, a hot-orange accent and mustard gold. IBM Plex Sans Arabic for UI with the Thmanyah Sans/Serif display faces. Full RTL + dark mode. Podcasts, documentaries, newsletters and longreads.",
  "author": { "name": "Abdullah Al-taheri", "url": "https://altaheri.me" },
  "license": "MIT",
  "homepage": "https://uikit.studio",

  "categories": ["marketing", "media", "editorial"],
  "tags": ["media", "podcast", "editorial", "magazine", "arabic", "rtl", "bilingual", "news"],

  "tech": {
    "frameworks": ["react"],
    "styling": "both",
    "tailwindVersion": "^4.0.0",
    "icons": "lucide",
    "deps": ["class-variance-authority", "clsx", "tailwind-merge"]
  },

  "design": {
    "tokens": "design/tokens.json",
    "tailwindPreset": "design/tailwind-preset.js",
    "themeCss": "design/theme.css",
    "fonts": [
      { "family": "IBM Plex Sans Arabic", "source": "local", "role": "sans" },
      { "family": "Thmanyah Sans", "source": "local", "role": "display" },
      { "family": "Thmanyah Serif", "source": "local", "role": "serif" }
    ],
    "palettes": [{ "name": "default", "primary": "#15110c", "accent": "#fa541c" }],
    "modes": ["light", "dark"]
  },

  "surface": {
    "components": [
      { "name": "Button", "react": "react/src/components/button.tsx" },
      { "name": "Card", "react": "react/src/components/card.tsx" },
      { "name": "Input", "react": "react/src/components/input.tsx" },
      { "name": "Badge", "react": "react/src/components/badge.tsx" },
      { "name": "Container", "react": "react/src/components/container.tsx" },
      { "name": "Cover", "react": "react/src/components/cover.tsx" }
    ],
    "blocks": [
      { "name": "Wordmark", "react": "react/src/blocks/wordmark.tsx" },
      { "name": "SectionHeader", "react": "react/src/blocks/section-header.tsx" },
      { "name": "Footer", "react": "react/src/blocks/footer.tsx" }
    ],
    "templates": [
      { "name": "Home", "route": "/", "preview": "screenshots/landing.png" },
      { "name": "Articles", "route": "/articles" },
      { "name": "Podcasts", "route": "/podcasts", "preview": "screenshots/podcasts.png" },
      { "name": "Components", "route": "/components", "preview": "screenshots/components.png" }
    ]
  },

  "prompts": {
    "origin": "prompts/build.md",
    "extend": "prompts/extend.md",
    "skillVersion": "uikit-standard@1.0"
  },

  "media": {
    "screenshots": [
      { "kind": "logo", "src": "screenshots/logo.svg" },
      { "kind": "landing", "src": "screenshots/landing.png" },
      { "kind": "landing", "src": "screenshots/landing-dark.png" },
      { "kind": "other", "src": "screenshots/components.png" },
      { "kind": "other", "src": "screenshots/podcasts.png" }
    ]
  }
}
