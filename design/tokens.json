{
  "$schema": "https://tr.designtokens.org/format/tokens.schema.json",
  "$description": "SADA design tokens (W3C DTCG). Editorial media-platform kit — cream paper + ink + hot orange + gold, IBM Plex Sans Arabic UI with Thmanyah Sans/Serif display, RTL-ready.",
  "color": {
    "$type": "color",
    "brand": {
      "50": { "$value": "#fff3ed" },
      "100": { "$value": "#ffe2d3" },
      "200": { "$value": "#ffc2a6" },
      "300": { "$value": "#ff9a6f" },
      "400": { "$value": "#fd6f3a" },
      "500": { "$value": "#fa541c" },
      "600": { "$value": "#e23d0a" },
      "700": { "$value": "#b62f09" },
      "800": { "$value": "#8f2710" },
      "900": { "$value": "#74230f" }
    },
    "gold": {
      "300": { "$value": "#f0cf7a" },
      "500": { "$value": "#e3b23c" },
      "700": { "$value": "#b8861f" }
    },
    "light": {
      "background": { "$value": "#f6f4ee" },
      "foreground": { "$value": "#15110c" },
      "card": { "$value": "#ffffff" },
      "muted": { "$value": "#ece8df" },
      "muted-foreground": { "$value": "#6f675b" },
      "border": { "$value": "#e2ddd2" },
      "primary": { "$value": "#15110c" },
      "primary-foreground": { "$value": "#f6f4ee" },
      "accent": { "$value": "#fa541c" },
      "ink": { "$value": "#15110c" },
      "mark": { "$value": "#fa541c" },
      "gold": { "$value": "#e3b23c" }
    },
    "dark": {
      "background": { "$value": "#14110c" },
      "foreground": { "$value": "#f4efe6" },
      "card": { "$value": "#1d1813" },
      "muted": { "$value": "#261f17" },
      "muted-foreground": { "$value": "#a89e8f" },
      "border": { "$value": "#322a20" },
      "primary": { "$value": "#f4efe6" },
      "accent": { "$value": "#fd6f3a" }
    }
  },
  "font": {
    "$type": "fontFamily",
    "display": { "$value": ["Thmanyah Sans", "IBM Plex Sans Arabic", "sans-serif"] },
    "sans": { "$value": ["IBM Plex Sans Arabic", "system-ui", "sans-serif"] },
    "serif": { "$value": ["Thmanyah Serif", "Georgia", "serif"] }
  },
  "radius": {
    "$type": "dimension",
    "DEFAULT": { "$value": "0.75rem" },
    "lg": { "$value": "1.25rem" },
    "xl": { "$value": "1.75rem" }
  }
}
